# Normalize all text files to LF in the repository.
* text=auto eol=lf

# Explicit text formats
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.sql text eol=lf
*.env.example text eol=lf

# Shell scripts should stay LF
*.sh text eol=lf

# Windows-specific scripts may use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files should not be normalized
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.mp4 binary
*.mov binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
